<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="IzinTakip.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:IzinTakip.Views"
    Title="İzin Takip">

    <!-- Login (tek sayfa, tab yok) -->
    <ShellContent Route="LoginPage"
                  ContentTemplate="{DataTemplate views:LoginPage}"
                  Shell.TabBarIsVisible="False" />

    <!-- Ana Sekmeler -->
    <TabBar Route="MainPage">
        <ShellContent Title="İzin Taleplerim"
                      Route="LeaveListPage"
                      Icon="izin_taleplerim.svg"
                      ContentTemplate="{DataTemplate views:LeaveListPage}" />
        <ShellContent Title="Yeni İzin Talebi"
                      Route="LeaveRequestPage"
                      Icon="yeni_talep.svg"
                      ContentTemplate="{DataTemplate views:LeaveRequestPage}" />
    </TabBar>

</Shell>
